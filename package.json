{
  "name": "repomate",
  "version": "0.1.0",
  "description": "Inject AI agents into any repository: GitHub Issue → Agent → PR workflow",
  "type": "module",
  "bin": {
    "repomate-server": "./server/index.js",
    "repomate-runner": "./bin/task-runner.sh",
    "repomate-worktree": "./bin/worktree.sh",
    "repomate-deploy": "./bin/deploy.sh",
    "repomate-setup": "./bin/setup.sh"
  },
  "exports": {
    "./server": "./server/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uyah/repomate.git"
  },
  "files": [
    "bin/",
    "server/",
    "templates/",
    "config.schema.json",
    "config.example.json"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@hono/node-server": "^1.14.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.4.7",
    "hono": "^4.7.6",
    "web-push": "^3.6.7"
  },
  "optionalDependencies": {
    "@slack/bolt": "^4.6.0"
  },
  "scripts": {
    "start": "node server/index.js"
  },
  "license": "MIT",
  "private": false
}
